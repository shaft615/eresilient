# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://eresilient.com

# Resend — transactional + lead-magnet nurture (PR #4)
RESEND_API_KEY=
RESEND_FROM_EMAIL=e|Resilient <info@eresilient.com>

# Vercel Postgres — subscriber list (PR #4)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Google Analytics 4 — measurement ID like G-XXXXXXXXXX (PR #6)
# Only loaded in production builds.
NEXT_PUBLIC_GA4_ID=

# Google Search Console — domain verification token (PR #6)
# Get from Search Console > Settings > Ownership verification > HTML tag.
# Use only the content="..." value, not the full meta tag.
NEXT_PUBLIC_GSC_VERIFICATION=

# Vercel Cron — shared secret for /api/cron/nurture (PR #7)
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically when
# this is set as a project env var. Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Unsubscribe token signing secret (PR #7) — HMAC key for one-click
# unsubscribe links in nurture emails. MUST be set in production. Rotating
# this invalidates every unsubscribe link currently in transit.
NURTURE_UNSUBSCRIBE_SECRET=

# Supabase — BIA tool auth + database
# Both values come from the Supabase project's Settings → API page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated allowlist of emails that may request magic links.
# Leave blank in dev to allow any email. Set in prod (e.g. on Vercel) for safety.
BIA_ALLOWED_EMAILS=

# bia-engine service — Python engine, used by /tools/bia for extract/render.
# Local dev: run `uvicorn bia_engine.api:app --port 8765` from bia-engine/ and use:
#   BIA_ENGINE_URL=http://127.0.0.1:8765
# Production: point at the Fly.io deploy:
#   BIA_ENGINE_URL=https://eresilient-bia-engine.fly.dev
BIA_ENGINE_URL=http://127.0.0.1:8765
# Shared HMAC secret. Leave empty for local dev (the engine also runs without
# the secret, so requests stay unsigned). Set in prod — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
BIA_API_SECRET=
