# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://eresilient.com

# Resend — transactional + lead-magnet nurture (PR #4)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Karl Bryant <karl.bryant@eresilient.com>

# Vercel Postgres — subscriber list (PR #4)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Google Analytics 4 — measurement ID like G-XXXXXXXXXX (PR #6)
# Only loaded in production builds.
NEXT_PUBLIC_GA4_ID=

# Google Search Console — domain verification token (PR #6)
# Get from Search Console > Settings > Ownership verification > HTML tag.
# Use only the content="..." value, not the full meta tag.
NEXT_PUBLIC_GSC_VERIFICATION=
